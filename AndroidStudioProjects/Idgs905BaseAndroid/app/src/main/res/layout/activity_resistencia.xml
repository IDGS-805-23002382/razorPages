<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#B7E3F0"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calcular Valor de resistencias"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:background="#B7FF00"
            android:padding="15dp" />

        <ImageView
            android:layout_width="250dp"
            android:layout_height="180dp"
            android:layout_marginTop="15dp"
            android:src="@drawable/tabla" />

        <!-- COLOR 1 -->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <Spinner
                android:id="@+id/spColor1"
                android:layout_width="160dp"
                android:layout_height="40dp"
                android:layout_marginRight="15dp"
                android:background="@color/black"

                />

            <TextView
                android:id="@+id/txtColor1"
                android:layout_width="60dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="0"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="20sp"
                android:background="#FFFFFF" />
        </LinearLayout>

        <!-- COLOR 2 -->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Spinner
                android:id="@+id/spColor2"
                android:layout_width="160dp"
                android:layout_height="40dp"
                android:layout_marginRight="15dp"
                android:background="@color/black" />

            <TextView
                android:id="@+id/txtColor2"
                android:layout_width="60dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="0"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="20sp"
                android:background="#FFFFFF" />
        </LinearLayout>

        <!-- MULTIPLICADOR -->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Spinner
                android:id="@+id/spMultiplicador"
                android:layout_width="160dp"
                android:layout_height="40dp"
                android:layout_marginRight="15dp"
                android:background="@color/black" />

            <TextView
                android:id="@+id/txtMultiplicador"
                android:layout_width="90dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="10^0"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="18sp"
                android:background="#FFFFFF" />
        </LinearLayout>

        <!-- TOLERANCIA -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tolerancia"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginTop="20dp" />

        <RadioGroup
            android:id="@+id/rgTolerancia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/rbOro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oro"
                android:textColor="#000000"
                android:buttonTint="#FFD700" />

            <RadioButton
                android:id="@+id/rbPlata"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Plata"
                android:textColor="#000000"
                android:buttonTint="#C0C0C0" />
        </RadioGroup>

        <!-- BOTON -->

        <Button
            android:id="@+id/btnCalcular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calcular"
            android:textColor="#000000"
            android:layout_marginTop="20dp"
            android:backgroundTint="#FFFFFF" />

        <!-- RESULTADOS -->

        <TextView
            android:id="@+id/tvOhm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Valor Ohm"
            android:textColor="#000000"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp" />

        <TextView
            android:id="@+id/tvMaximo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Valor Máximo"
            android:textColor="#000000"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvMinimo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Valor Mínimo"
            android:textColor="#000000"
            android:textSize="22sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>